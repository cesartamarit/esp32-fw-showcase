menu "Board Support Package"

    config BSP_LED_GPIO
        int "LED GPIO number"
        default 48
        help
            GPIO number for the onboard LED.
            ESP32-S3-DevKitC-1 uses GPIO48.

    config BSP_BUTTON_GPIO
        int "Boot button GPIO number"
        default 0
        help
            GPIO number for the onboard boot button.

    config BSP_I2C_SDA_GPIO
        int "I2C SDA GPIO number"
        default 8

    config BSP_I2C_SCL_GPIO
        int "I2C SCL GPIO number"
        default 9

    config BSP_I2C_FREQ_HZ
        int "I2C bus frequency (Hz)"
        default 400000
        help
            Standard mode: 100000, Fast mode: 400000.

endmenu
